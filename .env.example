# Copy to .env. EXPO_PUBLIC_ vars are inlined into the app bundle at build time.
# WARNING: EXPO_PUBLIC_OPENAI_API_KEY ships inside the app bundle and is
# extractable from any build — demo-grade only.
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-key
EXPO_PUBLIC_OPENAI_MODEL=gpt-5.4
EXPO_PUBLIC_OPENAI_IMAGE_MODEL=gpt-image-2
# Try-on render quality: low | medium | high (high keeps real skin/facial detail)
EXPO_PUBLIC_OPENAI_IMAGE_QUALITY=high
# Try-on output size: 1024x1024 | 1024x1536 | 1536x1024 (portrait matches the selfie)
EXPO_PUBLIC_OPENAI_IMAGE_SIZE=1024x1536

{
  "expo": {
    "name": "HaircutCon",
    "slug": "haircutcon",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "haircutcon",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haircutcon.app"
    },
    "android": {
      "package": "com.haircutcon.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "HaircutCon uses your photos to analyze your face shape and hair.",
          "cameraPermission": "HaircutCon uses the camera to take a selfie for face analysis."
        }
      ]
    ]
  }
}
